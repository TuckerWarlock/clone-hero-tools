[flake8]
# 95 gives Black's 88-char code a buffer for string literals and docstrings
# that Black cannot break automatically.
max-line-length = 95
# W503 — line break before binary operator conflicts with Black.
# E203 — whitespace before ':' in slices (Black handles this).
extend-ignore = E203, W503
exclude = .venv,.git,__pycache__
